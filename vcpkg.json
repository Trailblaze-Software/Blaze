{
  "name": "blaze",
  "version": "0.0.0",
  "dependencies": [
    {
      "name": "gdal",
      "default-features": false,
      "features": [
        "geos",
        "sqlite3"
      ],
      "version>=": "3.9.0"
    }
  ],
  "features": {
    "pdal": {
      "description": "Support for PDAL",
      "dependencies": [
        "pdal"
      ]
    },
    "gui": {
      "description": "Support for GUI",
      "dependencies": [
        {
          "name": "qtbase",
          "default-features": false,
          "features": [
            "brotli",
            "concurrent",
            "doubleconversion",
            "freetype",
            "gui",
            "harfbuzz",
            "icu",
            "jpeg",
            "opengl",
            "pcre2",
            "png",
            "thread",
            "widgets",
            "zstd"
          ]
        },
        {
          "name": "qtimageformats",
          "default-features": false,
          "features": [
            "tiff"
          ]
        }
      ]
    }
  }
}
